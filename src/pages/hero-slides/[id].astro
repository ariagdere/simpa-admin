---
// src/pages/hero-slides/[id].astro
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getHeroSlide } from '../../lib/queries.js';
import { resolveBrand } from '../../lib/adminUtils.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const { id } = Astro.params;
const isNew = id === 'new';

let slide;
let brand;

if (isNew) {
  brand = resolveBrand(Astro);
  slide = {
    id: null, brand, is_active: 1, mirror_layout: 0, show_on_tr: 1, show_on_en: 1,
    bg_color: '#1D1D1B', bg_image_url: '', bg_image_opacity: 60,
    badge_text_tr: '', badge_text_en: '', headline_tr: '', headline_en: '',
    highlight_word_tr: '', highlight_word_en: '', subtext_tr: '', subtext_en: '',
    fg_image_url_tr: '', fg_image_url_en: '',
    cta_primary_text_tr: '', cta_primary_text_en: '', cta_primary_link_tr: '', cta_primary_link_en: '',
    cta_secondary_text_tr: '', cta_secondary_text_en: '', cta_secondary_link_tr: '', cta_secondary_link_en: '',
    slide_link: '',
  };
} else {
  slide = await getHeroSlide(db, Number(id));
  if (!slide) {
    return new Response('Slayt bulunamadı', { status: 404 });
  }
  brand = slide.brand;
}

const val = (v) => v ?? '';
---
<AdminLayout title={isNew ? 'Yeni Slayt' : 'Slaytı Düzenle'} activeNav="hero-slides">
  <div class="a-page-header">
    <h1 class="a-h1">{isNew ? 'Yeni Slayt' : 'Slaytı Düzenle'} <span style="color:var(--a-text-muted);font-weight:400;font-size:14px">— {brand}</span></h1>
    <a class="back" href={`/hero-slides?brand=${brand}`} style="font-size:13px;color:var(--a-text-secondary);text-decoration:none">← Listeye dön</a>
  </div>
  <div style="margin-bottom:16px"></div>

    <form id="slideForm">
      <input type="hidden" name="id" value={val(slide.id)} />
      <input type="hidden" name="brand" value={brand} />

      <div class="section">
        <h2>Genel</h2>
        <div class="toggle-row">
          <div><div class="toggle-label">Aktif</div><div class="toggle-desc">Kapalıysa sitede hiç görünmez.</div></div>
          <label class="switch"><input type="checkbox" name="is_active" checked={!!slide.is_active} /><span class="track"></span><span class="thumb"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Aynalama</div><div class="toggle-desc">Açıksa görsel sola, metin sağa geçer.</div></div>
          <label class="switch"><input type="checkbox" name="mirror_layout" checked={!!slide.mirror_layout} /><span class="track"></span><span class="thumb"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Türkçe sitede göster</div><div class="toggle-desc">Kapalıysa TR sitede bu slayt hiç görünmez.</div></div>
          <label class="switch"><input type="checkbox" name="show_on_tr" checked={slide.show_on_tr !== 0} /><span class="track"></span><span class="thumb"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">İngilizce sitede göster</div><div class="toggle-desc">Kapalıysa EN sitede bu slayt hiç görünmez.</div></div>
          <label class="switch"><input type="checkbox" name="show_on_en" checked={slide.show_on_en !== 0} /><span class="track"></span><span class="thumb"></span></label>
        </div>
      </div>

      <div class="section">
        <h2>Arka Plan</h2>
        <div class="field">
          <label>Zemin Rengi</label>
          <div class="color-row">
            <input type="color" name="bg_color_picker" value={slide.bg_color || '#1D1D1B'} />
            <input type="text" name="bg_color" value={val(slide.bg_color)} placeholder="#1D1D1B" style="max-width:120px" />
          </div>
        </div>
        <div class="field">
          <label>Arka Plan Görseli <span class="hint">(opsiyonel — tanımlıysa zemin renginin üzerine biner)</span></label>
          <div class="upload-row">
            <input type="url" name="bg_image_url" value={val(slide.bg_image_url)} placeholder="https://..." />
            <button type="button" class="upload-btn" data-target="bg_image_url">Yükle</button>
          </div>
          <img class={`img-preview${slide.bg_image_url ? ' show' : ''}`} data-preview="bg_image_url" src={slide.bg_image_url || ''} />
        </div>
        <div class="field">
          <label>Görsel Saydamlığı <span class="hint">(0–100, sadece görsel varsa anlamlı)</span></label>
          <input type="number" name="bg_image_opacity" min="0" max="100" value={val(slide.bg_image_opacity)} style="max-width:100px" />
        </div>
      </div>

      <div class="section">
        <h2>Rozet</h2>
        <p class="section-hint">Boş bırakılırsa slaytta hiç rozet gösterilmez.</p>
        <div class="row2">
          <div class="field"><label>Rozet Metni (TR)</label><input type="text" name="badge_text_tr" value={val(slide.badge_text_tr)} /></div>
          <div class="field"><label>Rozet Metni (EN)</label><input type="text" name="badge_text_en" value={val(slide.badge_text_en)} /></div>
        </div>
      </div>

      <div class="section">
        <h2>Başlık</h2>
        <p class="section-hint">Boş bırakılırsa slaytta hiç başlık gösterilmez.</p>
        <div class="row2">
          <div class="field"><label>Başlık (TR)</label><input type="text" name="headline_tr" value={val(slide.headline_tr)} /></div>
          <div class="field"><label>Başlık (EN)</label><input type="text" name="headline_en" value={val(slide.headline_en)} /></div>
        </div>
        <div class="row2">
          <div class="field"><label>Vurgulanacak Kelime (TR) <span class="hint">turuncu renkte gösterilir</span></label><input type="text" name="highlight_word_tr" value={val(slide.highlight_word_tr)} /></div>
          <div class="field"><label>Vurgulanacak Kelime (EN)</label><input type="text" name="highlight_word_en" value={val(slide.highlight_word_en)} /></div>
        </div>
      </div>

      <div class="section">
        <h2>Alt Metin</h2>
        <p class="section-hint">Boş bırakılırsa slaytta hiç alt metin gösterilmez.</p>
        <div class="row2">
          <div class="field"><label>Alt Metin (TR)</label><textarea name="subtext_tr">{val(slide.subtext_tr)}</textarea></div>
          <div class="field"><label>Alt Metin (EN)</label><textarea name="subtext_en">{val(slide.subtext_en)}</textarea></div>
        </div>
      </div>

      <div class="section">
        <h2>Ön Plan Görseli</h2>
        <p class="section-hint">Boş bırakılırsa slaytta hiç görsel gösterilmez (katalog kutusunun durduğu yer). TR ve EN için farklı görsel (örn. üzerinde farklı dilde yazı olan katalog kapağı) yükleyebilirsin.</p>
        <div class="row2">
          <div class="field">
            <label>Görsel (TR)</label>
            <div class="upload-row">
              <input type="url" name="fg_image_url_tr" value={val(slide.fg_image_url_tr)} placeholder="https://..." />
              <button type="button" class="upload-btn" data-target="fg_image_url_tr">Yükle</button>
            </div>
            <img class={`img-preview${slide.fg_image_url_tr ? ' show' : ''}`} data-preview="fg_image_url_tr" src={slide.fg_image_url_tr || ''} />
          </div>
          <div class="field">
            <label>Görsel (EN)</label>
            <div class="upload-row">
              <input type="url" name="fg_image_url_en" value={val(slide.fg_image_url_en)} placeholder="https://..." />
              <button type="button" class="upload-btn" data-target="fg_image_url_en">Yükle</button>
            </div>
            <img class={`img-preview${slide.fg_image_url_en ? ' show' : ''}`} data-preview="fg_image_url_en" src={slide.fg_image_url_en || ''} />
          </div>
        </div>
      </div>

      <div class="section">
        <h2>Birincil Buton (CTA)</h2>
        <p class="section-hint">Boş bırakılırsa hiç gösterilmez.</p>
        <div class="row2">
          <div class="field"><label>Metin (TR)</label><input type="text" name="cta_primary_text_tr" value={val(slide.cta_primary_text_tr)} /></div>
          <div class="field"><label>Metin (EN)</label><input type="text" name="cta_primary_text_en" value={val(slide.cta_primary_text_en)} /></div>
        </div>
        <div class="row2">
          <div class="field"><label>Link (TR)</label><input type="text" name="cta_primary_link_tr" value={val(slide.cta_primary_link_tr)} placeholder="/kategori/" /></div>
          <div class="field"><label>Link (EN)</label><input type="text" name="cta_primary_link_en" value={val(slide.cta_primary_link_en)} placeholder="/en/category/" /></div>
        </div>
      </div>

      <div class="section">
        <h2>İkincil Buton (CTA)</h2>
        <p class="section-hint">Boş bırakılırsa hiç gösterilmez. Yeni sekmede açılır.</p>
        <div class="row2">
          <div class="field"><label>Metin (TR)</label><input type="text" name="cta_secondary_text_tr" value={val(slide.cta_secondary_text_tr)} /></div>
          <div class="field"><label>Metin (EN)</label><input type="text" name="cta_secondary_text_en" value={val(slide.cta_secondary_text_en)} /></div>
        </div>
        <div class="row2">
          <div class="field"><label>Link (TR)</label><input type="text" name="cta_secondary_link_tr" value={val(slide.cta_secondary_link_tr)} placeholder="https://... (katalog PDF)" /></div>
          <div class="field"><label>Link (EN)</label><input type="text" name="cta_secondary_link_en" value={val(slide.cta_secondary_link_en)} placeholder="https://... (catalog PDF)" /></div>
        </div>
      </div>

      <div class="section">
        <h2>Tüm Slaytı Tıklanabilir Yap</h2>
        <p class="section-hint">Sadece yukarıdaki iki buton da boşsa etkili olur. Doluysa tüm slayt bu linke gider; ikisi de boşsa slayt tıklanamaz.</p>
        <div class="field"><input type="text" name="slide_link" value={val(slide.slide_link)} placeholder="/kategori/ ya da https://..." /></div>
      </div>
    </form>

  <div class="save-bar">
    <div class="save-bar-in">
      <button type="button" class="btn-save" id="saveBtn">Kaydet</button>
      <span class="save-msg" id="saveMsg" style="display:none">Kaydedildi</span>
      <span class="save-err" id="saveErr" style="display:none"></span>
      {!isNew && <button type="button" class="btn-delete" id="deleteBtn" style="margin-left:auto;font-size:13px;color:#b91c1c;background:none;border:1px solid #f3d1d1;border-radius:6px;padding:9px 16px;cursor:pointer">Slaytı Sil</button>}
    </div>
  </div>

  <script define:vars={{ brand, slideId: slide.id }}>
    // Renk seçici (input[type=color]) ile hex text alanını senkronize et
    const colorPicker = document.querySelector('input[name="bg_color_picker"]');
    const colorText = document.querySelector('input[name="bg_color"]');
    colorPicker?.addEventListener('input', () => { colorText.value = colorPicker.value; });
    colorText?.addEventListener('input', () => {
      if (/^#[0-9a-fA-F]{6}$/.test(colorText.value)) colorPicker.value = colorText.value;
    });

    // Görsel yükleme butonları
    document.querySelectorAll('.upload-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetName = btn.dataset.target;
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = 'image/png,image/jpeg,image/webp,image/svg+xml';
        input.onchange = async () => {
          const file = input.files[0];
          if (!file) return;
          btn.disabled = true;
          btn.textContent = 'Yükleniyor…';
          try {
            const fd = new FormData();
            fd.append('file', file);
            const res = await fetch('/api/upload', { method: 'POST', body: fd });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Yükleme başarısız.');
            const urlInput = document.querySelector(`input[name="${targetName}"]`);
            urlInput.value = data.url;
            const preview = document.querySelector(`img[data-preview="${targetName}"]`);
            preview.src = data.url;
            preview.classList.add('show');
          } catch (err) {
            alert(err.message || 'Yükleme başarısız oldu.');
          } finally {
            btn.disabled = false;
            btn.textContent = 'Yükle';
          }
        };
        input.click();
      });
    });

    // Kaydet
    const saveBtn = document.getElementById('saveBtn');
    const saveMsg = document.getElementById('saveMsg');
    const saveErr = document.getElementById('saveErr');
    saveBtn.addEventListener('click', async () => {
      saveMsg.style.display = 'none';
      saveErr.style.display = 'none';
      saveBtn.disabled = true;
      saveBtn.textContent = 'Kaydediliyor…';

      const form = document.getElementById('slideForm');
      const formData = new FormData(form);
      const payload = {};
      for (const [key, value] of formData.entries()) {
        if (key === 'bg_color_picker') continue;
        payload[key] = value;
      }
      payload.is_active = form.querySelector('[name="is_active"]').checked;
      payload.mirror_layout = form.querySelector('[name="mirror_layout"]').checked;
      payload.show_on_tr = form.querySelector('[name="show_on_tr"]').checked;
      payload.show_on_en = form.querySelector('[name="show_on_en"]').checked;

      try {
        const res = await fetch('/api/hero-slides/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Kaydedilemedi.');
        saveMsg.style.display = 'inline';
        if (!slideId) {
          window.location.href = `/hero-slides/${data.id}`;
        }
      } catch (err) {
        saveErr.textContent = err.message || 'Kaydedilemedi.';
        saveErr.style.display = 'inline';
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Kaydet';
      }
    });

    // Sil
    document.getElementById('deleteBtn')?.addEventListener('click', async () => {
      if (!confirm('Bu slayt silinsin mi? Bu işlem geri alınamaz.')) return;
      const res = await fetch('/api/hero-slides/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: slideId }),
      });
      if (res.ok) {
        window.location.href = `/hero-slides?brand=${brand}`;
      } else {
        alert('Silinemedi, tekrar dene.');
      }
    });
  </script>
</AdminLayout>
