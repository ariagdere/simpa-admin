---
// src/pages/hero-slides/index.astro
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getHeroSlides } from '../../lib/queries.js';
import { resolveBrand } from '../../lib/adminUtils.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const brand = resolveBrand(Astro);
const slides = await getHeroSlides(db, brand);
---
<AdminLayout title="Hero Slaytlar" activeNav="hero-slides" showBrandSwitcher brand={brand}>
  <div class="a-page-header">
    <h1 class="a-h1">Hero Slaytlar</h1>
  </div>
  <p class="a-sub" style="margin-bottom:20px">Ana sayfada dönen hero alanını yönetin. Tek slayt varsa statik görünür, 2+ olunca otomatik geçişli hale gelir.</p>

  <a class="a-btn a-btn-primary" href={`/hero-slides/new?brand=${brand}`} style="margin-bottom:16px">+ Yeni Slayt</a>

  <div id="slideList">
    {slides.length === 0 && <div class="a-list-empty">Bu markada henüz slayt yok.</div>}
    {slides.map((s, i) => (
      <div class="a-list-card" data-id={s.id}>
        <div style="display:flex;flex-direction:column;gap:2px">
          <button type="button" class="move-up" data-id={s.id} disabled={i === 0} style="width:22px;height:18px;border:1px solid var(--a-border);background:#fff;border-radius:4px;cursor:pointer;font-size:10px;color:var(--a-text-secondary)">▲</button>
          <button type="button" class="move-down" data-id={s.id} disabled={i === slides.length - 1} style="width:22px;height:18px;border:1px solid var(--a-border);background:#fff;border-radius:4px;cursor:pointer;font-size:10px;color:var(--a-text-secondary)">▼</button>
        </div>
        <span class={`a-dot ${s.is_active ? 'a-dot-on' : 'a-dot-off'}`} title={s.is_active ? 'Aktif' : 'Pasif'}></span>
        <div style="flex:1;min-width:0">
          <div style="font-size:14px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{s.headline_tr || <em>(başlık yok)</em>}</div>
          <div style="font-size:12px;color:var(--a-text-muted);margin-top:2px">{s.badge_text_tr || '—'} · sıra: {s.sort_order}</div>
        </div>
        <div style="display:flex;gap:8px">
          <a class="a-btn a-btn-sm" href={`/hero-slides/${s.id}`}>Düzenle</a>
          <button type="button" class="a-btn a-btn-sm a-btn-danger btn-delete" data-id={s.id} data-headline={s.headline_tr || 'bu slayt'}>Sil</button>
        </div>
      </div>
    ))}
  </div>

  <script define:vars={{ brand }}>
    document.querySelectorAll('.btn-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const headline = btn.dataset.headline;
        if (!confirm(`"${headline}" silinsin mi? Bu işlem geri alınamaz.`)) return;
        const res = await fetch('/api/hero-slides/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Silinemedi, tekrar dene.');
        }
      });
    });

    function currentOrder() {
      return Array.from(document.querySelectorAll('[data-id]')).filter((el) => el.classList.contains('a-list-card')).map((c) => c.dataset.id);
    }

    async function saveOrder(ids) {
      await fetch('/api/hero-slides/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      });
    }

    document.querySelectorAll('.move-up').forEach((btn) => {
      btn.onclick = async () => {
        const card = btn.closest('.a-list-card');
        const prev = card.previousElementSibling;
        if (prev) {
          card.parentNode.insertBefore(card, prev);
          await saveOrder(currentOrder());
          window.location.reload();
        }
      };
    });
    document.querySelectorAll('.move-down').forEach((btn) => {
      btn.onclick = async () => {
        const card = btn.closest('.a-list-card');
        const next = card.nextElementSibling;
        if (next) {
          card.parentNode.insertBefore(next, card);
          await saveOrder(currentOrder());
          window.location.reload();
        }
      };
    });
  </script>
</AdminLayout>
