---
// src/pages/hero-slides/index.astro
export const prerender = false;

import { getHeroSlides } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const url = new URL(Astro.request.url);
const brand = url.searchParams.get('brand') === 'Superpress' ? 'Superpress' : 'Simpa';

const slides = await getHeroSlides(db, brand);
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hero Slaytlar — Admin Panel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, 'Segoe UI', Roboto, sans-serif; background: #f4f5f7; color: #1e2535; padding: 32px 24px; }
    .wrap { max-width: 900px; margin: 0 auto; }
    .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    h1 { font-size: 20px; }
    a.back { font-size: 13px; color: #6b7280; text-decoration: none; }
    .sub { color: #6b7280; font-size: 14px; margin-bottom: 24px; }

    .tabs { display: flex; gap: 4px; background: #e9eaed; border-radius: 8px; padding: 4px; width: fit-content; margin-bottom: 20px; }
    .tab { padding: 7px 16px; border-radius: 6px; font-size: 13.5px; font-weight: 600; text-decoration: none; color: #6b7280; }
    .tab.active { background: #fff; color: #1e2535; box-shadow: 0 1px 2px rgba(0,0,0,.08); }

    .add-btn { display: inline-block; background: #1e2535; color: #fff; font-size: 13.5px; font-weight: 600; padding: 9px 16px; border-radius: 6px; text-decoration: none; margin-bottom: 16px; }

    .slide-card { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 14px 18px; margin-bottom: 10px; display: flex; align-items: center; gap: 14px; }
    .slide-order { display: flex; flex-direction: column; gap: 2px; }
    .slide-order button { width: 22px; height: 18px; border: 1px solid #d7d9dd; background: #fff; border-radius: 4px; cursor: pointer; font-size: 10px; color: #6b7280; }
    .slide-order button:disabled { opacity: .3; cursor: default; }

    .slide-status { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .slide-status.on { background: #22c55e; }
    .slide-status.off { background: #d1d5db; }

    .slide-info { flex: 1; min-width: 0; }
    .slide-headline { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .slide-meta { font-size: 12px; color: #9ca3af; margin-top: 2px; }

    .slide-actions { display: flex; gap: 8px; }
    .btn-edit { font-size: 12.5px; font-weight: 600; color: #1e5fa8; text-decoration: none; padding: 6px 12px; border: 1px solid #d7d9dd; border-radius: 6px; }
    .btn-delete { font-size: 12.5px; font-weight: 600; color: #b91c1c; background: none; border: 1px solid #f3d1d1; border-radius: 6px; padding: 6px 12px; cursor: pointer; }

    .empty { text-align: center; padding: 48px 20px; color: #9ca3af; font-size: 14px; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <h1>Hero Slaytlar</h1>
      <a class="back" href="/">← Panel</a>
    </div>
    <p class="sub">Ana sayfada dönen hero alanını yönetin. Tek slayt varsa statik görünür, 2+ olunca otomatik geçişli hale gelir.</p>

    <div class="tabs">
      <a class="tab{brand === 'Simpa' ? ' active' : ''}" href="/hero-slides?brand=Simpa">Simpa Elektrik</a>
      <a class="tab{brand === 'Superpress' ? ' active' : ''}" href="/hero-slides?brand=Superpress">Superpress</a>
    </div>

    <a class="add-btn" href={`/hero-slides/new?brand=${brand}`}>+ Yeni Slayt</a>

    <div id="slideList">
      {slides.length === 0 && <div class="empty">Bu markada henüz slayt yok.</div>}
      {slides.map((s, i) => (
        <div class="slide-card" data-id={s.id}>
          <div class="slide-order">
            <button type="button" class="move-up" data-id={s.id} disabled={i === 0}>▲</button>
            <button type="button" class="move-down" data-id={s.id} disabled={i === slides.length - 1}>▼</button>
          </div>
          <span class={`slide-status ${s.is_active ? 'on' : 'off'}`} title={s.is_active ? 'Aktif' : 'Pasif'}></span>
          <div class="slide-info">
            <div class="slide-headline">{s.headline_tr || <em>(başlık yok)</em>}</div>
            <div class="slide-meta">{s.badge_text_tr || '—'} · sıra: {s.sort_order}</div>
          </div>
          <div class="slide-actions">
            <a class="btn-edit" href={`/hero-slides/${s.id}`}>Düzenle</a>
            <button type="button" class="btn-delete" data-id={s.id} data-headline={s.headline_tr || 'bu slayt'}>Sil</button>
          </div>
        </div>
      ))}
    </div>
  </div>

  <script define:vars={{ brand }}>
    document.querySelectorAll('.btn-delete').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const headline = btn.dataset.headline;
        if (!confirm(`"${headline}" silinsin mi? Bu işlem geri alınamaz.`)) return;
        const res = await fetch('/api/hero-slides/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          alert('Silinemedi, tekrar dene.');
        }
      });
    });

    function currentOrder() {
      return Array.from(document.querySelectorAll('.slide-card')).map((c) => c.dataset.id);
    }

    async function saveOrder(ids) {
      await fetch('/api/hero-slides/reorder', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ids }),
      });
    }

    function attachMoveHandlers() {
      document.querySelectorAll('.move-up').forEach((btn) => {
        btn.onclick = async () => {
          const card = btn.closest('.slide-card');
          const prev = card.previousElementSibling;
          if (prev) {
            card.parentNode.insertBefore(card, prev);
            await saveOrder(currentOrder());
            window.location.reload();
          }
        };
      });
      document.querySelectorAll('.move-down').forEach((btn) => {
        btn.onclick = async () => {
          const card = btn.closest('.slide-card');
          const next = card.nextElementSibling;
          if (next) {
            card.parentNode.insertBefore(next, card);
            await saveOrder(currentOrder());
            window.location.reload();
          }
        };
      });
    }
    attachMoveHandlers();
  </script>
</body>
</html>
