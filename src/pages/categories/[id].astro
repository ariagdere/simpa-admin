---
// src/pages/categories/[id].astro
export const prerender = false;

import { getCategoryById } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const { id } = Astro.params;
const isNew = id === 'new';

let category;
if (isNew) {
  category = { id: null, name_tr: '', name_en: '', slug: '', image_url: '' };
} else {
  category = await getCategoryById(db, Number(id));
  if (!category) {
    return new Response('Kategori bulunamadı', { status: 404 });
  }
}

const val = (v) => v ?? '';
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{isNew ? 'Yeni Kategori' : 'Kategoriyi Düzenle'} — Admin Panel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, 'Segoe UI', Roboto, sans-serif; background: #f4f5f7; color: #1e2535; padding: 32px 24px 80px; }
    .wrap { max-width: 560px; margin: 0 auto; }
    .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    h1 { font-size: 20px; }
    a.back { font-size: 13px; color: #6b7280; text-decoration: none; }

    .section { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 20px 22px; margin-bottom: 16px; }
    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .field { margin-bottom: 14px; }
    .field:last-child { margin-bottom: 0; }
    label { display: block; font-size: 12.5px; font-weight: 600; color: #374151; margin-bottom: 5px; }
    label .hint { font-weight: 400; color: #9ca3af; }
    input[type="text"], input[type="url"] {
      width: 100%; padding: 8px 10px; border: 1px solid #d7d9dd; border-radius: 6px; font-size: 13.5px; font-family: inherit; color: #1e2535;
    }
    .warn { font-size: 12px; color: #b45309; background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 8px 10px; margin-top: 6px; }

    .upload-row { display: flex; gap: 8px; align-items: flex-start; }
    .upload-row input[type="url"] { flex: 1; }
    .upload-btn { flex-shrink: 0; font-size: 12.5px; font-weight: 600; padding: 8px 12px; border: 1px solid #d7d9dd; background: #fff; border-radius: 6px; cursor: pointer; white-space: nowrap; }
    .upload-btn:disabled { opacity: .5; cursor: default; }
    .img-preview { margin-top: 8px; max-width: 140px; max-height: 100px; border-radius: 6px; border: 1px solid #e5e7eb; display: none; }
    .img-preview.show { display: block; }

    .save-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid #e5e7eb; padding: 14px 24px; display: flex; justify-content: center; }
    .save-bar-in { max-width: 560px; width: 100%; display: flex; gap: 10px; align-items: center; }
    .btn-save { background: #1e2535; color: #fff; font-size: 14px; font-weight: 600; padding: 10px 22px; border-radius: 6px; border: none; cursor: pointer; }
    .btn-save:disabled { opacity: .6; cursor: default; }
    .save-msg { font-size: 13px; color: #22c55e; font-weight: 600; }
    .save-err { font-size: 13px; color: #b91c1c; font-weight: 600; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <h1>{isNew ? 'Yeni Kategori' : 'Kategoriyi Düzenle'}</h1>
      <a class="back" href="/categories">← Listeye dön</a>
    </div>

    <form id="catForm">
      <input type="hidden" name="id" value={val(category.id)} />

      <div class="section">
        <div class="row2">
          <div class="field"><label>İsim (TR) *</label><input type="text" name="name_tr" value={val(category.name_tr)} required /></div>
          <div class="field"><label>İsim (EN)</label><input type="text" name="name_en" value={val(category.name_en)} /></div>
        </div>
        <div class="field">
          <label>Slug <span class="hint">(URL'de görünen kısım, örn. /kategori/kablo-pabuclari)</span></label>
          <input type="text" name="slug" value={val(category.slug)} placeholder={isNew ? '(boş bırakırsan isimden otomatik oluşur)' : ''} />
          {!isNew && <div class="warn">Bu alanı değiştirirsen, bu kategoriye giden mevcut linkler ve arama motoru kayıtları kırılır. Gerekmedikçe dokunma.</div>}
        </div>
      </div>

      <div class="section">
        <div class="field">
          <label>Kategori Görseli</label>
          <div class="upload-row">
            <input type="url" name="image_url" value={val(category.image_url)} placeholder="https://..." />
            <button type="button" class="upload-btn" id="uploadBtn">Yükle</button>
          </div>
          <img class={`img-preview${category.image_url ? ' show' : ''}`} id="imgPreview" src={category.image_url || ''} />
        </div>
      </div>
    </form>
  </div>

  <div class="save-bar">
    <div class="save-bar-in">
      <button type="button" class="btn-save" id="saveBtn">Kaydet</button>
      <span class="save-msg" id="saveMsg" style="display:none">Kaydedildi</span>
      <span class="save-err" id="saveErr" style="display:none"></span>
    </div>
  </div>

  <script>
    const uploadBtn = document.getElementById('uploadBtn');
    uploadBtn.addEventListener('click', () => {
      const input = document.createElement('input');
      input.type = 'file';
      input.accept = 'image/png,image/jpeg,image/webp,image/svg+xml';
      input.onchange = async () => {
        const file = input.files[0];
        if (!file) return;
        uploadBtn.disabled = true;
        uploadBtn.textContent = 'Yükleniyor…';
        try {
          const fd = new FormData();
          fd.append('file', file);
          const res = await fetch('/api/upload', { method: 'POST', body: fd });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Yükleme başarısız.');
          document.querySelector('input[name="image_url"]').value = data.url;
          const preview = document.getElementById('imgPreview');
          preview.src = data.url;
          preview.classList.add('show');
        } catch (err) {
          alert(err.message || 'Yükleme başarısız oldu.');
        } finally {
          uploadBtn.disabled = false;
          uploadBtn.textContent = 'Yükle';
        }
      };
      input.click();
    });

    const saveBtn = document.getElementById('saveBtn');
    const saveMsg = document.getElementById('saveMsg');
    const saveErr = document.getElementById('saveErr');
    saveBtn.addEventListener('click', async () => {
      saveMsg.style.display = 'none';
      saveErr.style.display = 'none';

      const form = document.getElementById('catForm');
      const nameTr = form.querySelector('[name="name_tr"]').value.trim();
      if (!nameTr) {
        saveErr.textContent = 'Türkçe isim zorunlu.';
        saveErr.style.display = 'inline';
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = 'Kaydediliyor…';

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      try {
        const res = await fetch('/api/categories/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Kaydedilemedi.');
        saveMsg.style.display = 'inline';
        if (!payload.id) {
          window.location.href = `/categories/${data.id}`;
        }
      } catch (err) {
        saveErr.textContent = err.message || 'Kaydedilemedi.';
        saveErr.style.display = 'inline';
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Kaydet';
      }
    });
  </script>
</body>
</html>
