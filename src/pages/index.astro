---
// src/pages/index.astro
export const prerender = false;
import AdminLayout from '../layouts/AdminLayout.astro';
import { getDashboardStats } from '../lib/queries.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const stats = await getDashboardStats(db);

const NAV = [
  { href: '/hero-slides', label: 'Hero Slaytlar', desc: 'Ana sayfa slider içeriği' },
  { href: '/categories', label: 'Kategoriler', desc: 'Ürün kategorileri' },
  { href: '/products', label: 'Ürünler', desc: 'Temel bilgi, künye, teknik veri, görsel' },
  { href: '/fields', label: 'Teknik Alan Tanımları', desc: 'Künye ve varyant alanları' },
  { href: '/page-content', label: 'Statik Sayfa İçerikleri', desc: 'Hakkımızda, Gizlilik ve Güvenlik' },
  { href: '/company-info', label: 'Şirket Künyesi', desc: 'Ünvan, adres, iletişim, sosyal medya' },
];
---
<AdminLayout title="Panel" activeNav="home">
  <div class="a-page-header">
    <h1 class="a-h1">Admin Panel</h1>
  </div>
  <p class="a-sub" style="margin-bottom:28px">Simpa Elektrik &amp; Superpress ortak yönetim paneli.</p>

  <div class="a-card">
    <h2 class="a-h2">Durum</h2>
    <div style="display:flex;gap:32px;flex-wrap:wrap">
      <div>
        <div style="font-size:12px;color:var(--a-text-secondary);margin-bottom:4px">Simpa ürünleri</div>
        <div style="font-size:20px;font-weight:600">{stats.simpaProducts}</div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--a-text-secondary);margin-bottom:4px">Superpress ürünleri</div>
        <div style="font-size:20px;font-weight:600">{stats.superpressProducts}</div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--a-text-secondary);margin-bottom:4px">Kategoriler</div>
        <div style="font-size:20px;font-weight:600">{stats.categories}</div>
      </div>
    </div>
  </div>

  <div class="a-card" style="padding:0;overflow:hidden">
    {NAV.map((item, i) => (
      <a href={item.href} style={`display:flex;align-items:center;justify-content:space-between;padding:16px 22px;text-decoration:none;color:inherit;${i > 0 ? 'border-top:1px solid var(--a-border-light)' : ''}`}>
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--a-text)">{item.label}</div>
          <div style="font-size:12.5px;color:var(--a-text-secondary);margin-top:2px">{item.desc}</div>
        </div>
        <span style="color:var(--a-text-muted);font-size:16px">→</span>
      </a>
    ))}
  </div>
</AdminLayout>
