---
// src/pages/products/[id].astro
export const prerender = false;

import {
  getProductById,
  getCategoriesAdmin,
  getProductSpecsAdmin,
  getFieldLabelsGrouped,
  getProductVariantsAdmin,
  getProductKunyeFields,
  getAllCertificatesAdmin,
  getProductCertificateTags,
  getProductCompatibilityList,
  getProductImages,
} from '../../lib/queries.js';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { env } from 'cloudflare:workers';

const db = env.DB;
const { id } = Astro.params;
const url = new URL(Astro.request.url);
const isNew = id === 'new';

let product;
let specs;
let variants = [];
let kunyeGroups = [];
let allCertificates = [];
let selectedCertTags = [];
let compatList = [];
let images = [];

if (isNew) {
  product = {
    id: null, prod_code: '', title_tr: '', title_en: '', category_id: '',
    brand: url.searchParams.get('brand') === 'Superpress' ? 'Superpress' : 'Simpa',
    drawing_ref: '', has_variant_table: 1, is_active: 0,
  };
  specs = { ozellikler_tr: '', ozellikler_en: '', special_note_tr: '', special_note_en: '' };
} else {
  product = await getProductById(db, Number(id));
  if (!product) {
    return new Response('Ürün bulunamadı', { status: 404 });
  }
  specs = await getProductSpecsAdmin(db, Number(id));
  kunyeGroups = await getProductKunyeFields(db, Number(id));
  allCertificates = await getAllCertificatesAdmin(db);
  selectedCertTags = await getProductCertificateTags(db, Number(id));
  compatList = await getProductCompatibilityList(db, Number(id));
  images = await getProductImages(db, Number(id));
  if (product.has_variant_table) {
    variants = await getProductVariantsAdmin(db, Number(id));
  }
}

const categories = await getCategoriesAdmin(db);
const fieldGroups = (await getFieldLabelsGrouped(db, 'variant'))
  .map((g) => ({ ...g, fields: g.fields.filter((f) => f.attr_key !== 'OZELLIKLER' && f.attr_key !== 'SPECIAL_NOTE') }))
  .filter((g) => g.fields.length > 0);
const fieldLabels = fieldGroups.flatMap((g) => g.fields);

const val = (v) => v ?? '';
---
<AdminLayout title={isNew ? 'Yeni Ürün' : (product.title_tr || product.title_en)} activeNav="products">
  <div class="a-page-header">
    <h1 class="a-h1">{isNew ? 'Yeni Ürün' : (product.title_tr || product.title_en)}</h1>
    <a class="back" href="/products" style="font-size:13px;color:var(--a-text-secondary);text-decoration:none">← Listeye dön</a>
  </div>
  <div style="margin-bottom:16px"></div>

    <form id="prodForm">
      <input type="hidden" name="id" value={val(product.id)} />

      <div class="section">
        <h2>Temel Bilgiler</h2>
        <div class="row2">
          <div class="field"><label>Ürün Kodu *</label><input type="text" name="prod_code" value={val(product.prod_code)} required /></div>
          <div class="field">
            <label>Marka *</label>
            <select name="brand">
              <option value="Simpa" selected={product.brand === 'Simpa'}>Simpa</option>
              <option value="Superpress" selected={product.brand === 'Superpress'}>Superpress</option>
            </select>
          </div>
        </div>
        <div class="row2">
          <div class="field"><label>Başlık (TR) *</label><input type="text" name="title_tr" value={val(product.title_tr)} required /></div>
          <div class="field"><label>Başlık (EN)</label><input type="text" name="title_en" value={val(product.title_en)} /></div>
        </div>
        <div class="row2">
          <div class="field">
            <label>Kategori</label>
            <select name="category_id">
              <option value="">Seçiniz</option>
              {categories.map((c) => <option value={c.id} selected={product.category_id === c.id}>{c.name_tr}</option>)}
            </select>
          </div>
          <div class="field"><label>Teknik Çizim Referansı</label><input type="text" name="drawing_ref" value={val(product.drawing_ref)} /></div>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Aktif</div><div class="toggle-desc">Kapalıysa sitede hiç görünmez.</div></div>
          <label class="switch"><input type="checkbox" name="is_active" checked={!!product.is_active} /><span class="track"></span><span class="thumb"></span></label>
        </div>
        <div class="toggle-row">
          <div><div class="toggle-label">Varyant Tablosu Kullansın</div><div class="toggle-desc">Kapalıysa bu ürün tekil bir SKU'dur, aşağıdaki teknik veri tablosu hiç gösterilmez.</div></div>
          <label class="switch"><input type="checkbox" name="has_variant_table" checked={!!product.has_variant_table} /><span class="track"></span><span class="thumb"></span></label>
        </div>
      </div>

      <div class="section">
        <h2>Açıklama</h2>
        <div class="row2">
          <div class="field"><label>Ürün Açıklaması (TR)</label><textarea name="ozellikler_tr">{val(specs.ozellikler_tr)}</textarea></div>
          <div class="field"><label>Ürün Açıklaması (EN)</label><textarea name="ozellikler_en">{val(specs.ozellikler_en)}</textarea></div>
        </div>
        <div class="row2" style="margin-top:14px">
          <div class="field"><label>Özel Not (TR) <span style="font-weight:400;color:#9ca3af">— künye altında sarı kutuda çıkar</span></label><textarea name="special_note_tr">{val(specs.special_note_tr)}</textarea></div>
          <div class="field"><label>Özel Not (EN)</label><textarea name="special_note_en">{val(specs.special_note_en)}</textarea></div>
        </div>
      </div>
    </form>

    {!isNew && (
      <div class="section">
        <h2>Görseller</h2>
        <p class="section-hint">Ok butonlarıyla sırala, yıldıza tıklayarak ana görseli seç.</p>
        <div id="imageGrid" class="image-grid">
          {images.map((img, i) => (
            <div class="image-card" data-id={img.id}>
              <img src={img.file_url} alt="" />
              <button type="button" class={`img-star${img.is_primary ? ' active' : ''}`} title="Ana görsel yap">★</button>
              <div class="img-order-btns">
                <button type="button" class="img-move-up" disabled={i === 0}>◀</button>
                <button type="button" class="img-move-down" disabled={i === images.length - 1}>▶</button>
              </div>
              <button type="button" class="img-del" title="Sil">✕</button>
            </div>
          ))}
          <label for="imageFileInput" class="image-add-card">+ Görsel Ekle</label>
        </div>
        <input type="file" id="imageFileInput" accept="image/png,image/jpeg,image/webp" style="display:none" multiple />
        <div id="imageUploadStatus" style="font-size:12.5px;color:#6b7280;margin-top:8px;display:none"></div>
      </div>
    )}

    {!isNew && kunyeGroups.length > 0 && (
      <div class="section">
        <h2>Künye / Ürün Bilgileri</h2>
        <p class="section-hint">Ürün başına tek değer, künye kutusunda görünür. Yeni alan eklemek için <a href="/fields" target="_blank" style="color:#1e5fa8">Teknik Alan Tanımları</a>'na git.</p>
        {kunyeGroups.map((g) => (
          <div style="margin-bottom:18px">
            <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;color:#6b7280;margin-bottom:8px">{g.group_label_tr}</div>
            {g.fields.map((f) => (
              <div class="kunye-row" data-key={f.attr_key} style="display:grid;grid-template-columns:140px 1fr 1fr auto;gap:8px;align-items:center;margin-bottom:6px">
                <label style="font-size:12.5px;color:#374151">{f.label_tr}{f.unit && ` (${f.unit})`}</label>
                <input type="text" data-field="value_tr" value={f.value_tr} placeholder="TR" />
                <input type="text" data-field="value_en" value={f.value_en} placeholder="EN" />
                <button type="button" class="kunye-save row-save">Kaydet</button>
              </div>
            ))}
          </div>
        ))}
      </div>
    )}

    {!isNew && (
      <div class="section">
        <h2>Sertifikalar</h2>
        <p class="section-hint">Bu ürüne uygulanan sertifikaları işaretle.</p>
        <div id="certList" style="display:flex;flex-direction:column;gap:8px;margin-bottom:14px">
          {allCertificates.map((c) => (
            <label style="display:flex;align-items:center;gap:8px;font-size:13.5px">
              <input type="checkbox" value={c.tag} checked={selectedCertTags.includes(c.tag)} />
              {c.name}
            </label>
          ))}
        </div>
        <button type="button" class="btn-save" id="saveCertsBtn" style="padding:8px 16px;font-size:13px">Sertifikaları Kaydet</button>
        <span class="save-msg" id="certMsg" style="display:none;margin-left:8px">Kaydedildi</span>
      </div>
    )}

    {!isNew && (
      <div class="section">
        <h2>Uyumlu Ürünler</h2>
        <p class="section-hint">Bu ürünle uyumlu diğer ürünleri ara ve ekle. İki yönlü kaydedilir (o üründe de bu görünür).</p>
        <div style="position:relative;margin-bottom:14px">
          <input type="text" id="compatSearch" placeholder="Ürün kodu veya isim ara..." style="width:100%;padding:9px 12px;border:1px solid #d7d9dd;border-radius:6px;font-size:13.5px" />
          <div id="compatResults" style="display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border:1px solid #e5e7eb;border-radius:6px;margin-top:4px;max-height:220px;overflow-y:auto;z-index:5;box-shadow:0 4px 12px rgba(0,0,0,.08)"></div>
        </div>
        <div id="compatList" style="display:flex;flex-direction:column;gap:6px">
          {compatList.map((p) => (
            <div class="compat-item" data-id={p.id} style="display:flex;align-items:center;justify-content:space-between;background:#f4f5f7;padding:8px 12px;border-radius:6px;font-size:13px">
              <span><strong>{p.prod_code}</strong> — {p.title_tr || p.title_en}</span>
              <button type="button" class="compat-remove" style="font-size:11px;color:#b91c1c;background:none;border:none;cursor:pointer">Kaldır</button>
            </div>
          ))}
        </div>
      </div>
    )}


    {!isNew && !!product.has_variant_table && (
      <div class="section">
        <h2>Teknik Veri — Varyantlar</h2>
        <div class="variant-note">Her satır ayrı kaydedilir — bir satırı değiştirdikten sonra o satırın "Kaydet"ine bas. Yeni bir sütun/alan eklemek için <a href="/fields" target="_blank" style="color:#1e5fa8">Teknik Alan Tanımları</a>'na git.</div>

        <div class="excel-bar">
          <a class="btn-excel" href={`/api/products/export-excel?id=${product.id}`}>⬇ Excel'e Aktar</a>
          <label class="btn-excel" for="excelFileInput">⬆ Excel'den Yükle</label>
          <input type="file" id="excelFileInput" accept=".xlsx" style="display:none" />
        </div>

        <div id="excelPreview" style="display:none" class="excel-preview">
          <div id="excelPreviewSummary" style="font-size:13.5px;font-weight:600;margin-bottom:10px"></div>
          <div id="excelPreviewError" class="form-err" style="display:none;margin-bottom:10px"></div>
          <div style="max-height:260px;overflow-y:auto;border:1px solid #e5e7eb;border-radius:6px;margin-bottom:12px">
            <table id="excelPreviewTable" style="width:100%;border-collapse:collapse;font-size:12px"></table>
          </div>
          <div style="display:flex;gap:8px">
            <button type="button" class="btn-save" id="excelApplyBtn">Onayla ve Kaydet</button>
            <button type="button" class="btn-excel" id="excelCancelBtn">Vazgeç</button>
          </div>
        </div>

        <div class="table-scroll">
          <table class="vtable" id="vtable">
            <thead>
              <tr>
                <th rowspan="2">Varyant Kodu</th>
                {fieldGroups.map((g) => (
                  g.group_key
                    ? <th colspan={g.fields.length} style="text-align:center;border-bottom:1px solid #e5e7eb">{g.group_label_tr}</th>
                    : g.fields.map((f) => <th rowspan="2">{f.label_tr}{f.unit && ` (${f.unit})`}</th>)
                ))}
                <th rowspan="2"></th>
              </tr>
              <tr>
                {fieldGroups.map((g) => g.group_key && g.fields.map((f) => <th>{f.label_tr}{f.unit && ` (${f.unit})`}</th>))}
              </tr>
            </thead>
            <tbody id="vtableBody">
              {variants.map((v) => (
                <tr data-variant-id={v.id}>
                  <td><input type="text" class="code-input" value={v.variant_code} data-field="__code" /></td>
                  {fieldLabels.map((f) => <td><input type="text" value={v.values[f.attr_key] || ''} data-field={f.attr_key} /></td>)}
                  <td class="row-actions">
                    <button type="button" class="row-save">Kaydet</button>
                    <button type="button" class="row-del">Sil</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <button type="button" class="add-row-btn" id="addRowBtn">+ Yeni Varyant Satırı</button>
      </div>
    )}

    {isNew && (
      <p style="font-size:13px;color:#9ca3af;text-align:center;margin-top:8px">Teknik veri tablosunu düzenlemek için önce ürünü bir kez kaydet.</p>
    )}

  <div class="save-bar">
    <div class="save-bar-in">
      <button type="button" class="btn-save" id="saveBtn">Kaydet</button>
      <span class="save-msg" id="saveMsg" style="display:none">Kaydedildi</span>
      <span class="save-err" id="saveErr" style="display:none"></span>
      {!isNew && <button type="button" class="btn-delete-product" id="deleteProductBtn">Ürünü Sil</button>}
    </div>
  </div>

  <script define:vars={{ productId: product.id, fieldKeys: fieldLabels.map((f) => f.attr_key) }}>
    // Ürün temel bilgi + açıklama kaydet
    const saveBtn = document.getElementById('saveBtn');
    const saveMsg = document.getElementById('saveMsg');
    const saveErr = document.getElementById('saveErr');
    saveBtn.addEventListener('click', async () => {
      saveMsg.style.display = 'none';
      saveErr.style.display = 'none';

      const form = document.getElementById('prodForm');
      const prodCode = form.querySelector('[name="prod_code"]').value.trim();
      const titleTr = form.querySelector('[name="title_tr"]').value.trim();
      if (!prodCode || !titleTr) {
        saveErr.textContent = 'Ürün kodu ve Türkçe başlık zorunlu.';
        saveErr.style.display = 'inline';
        return;
      }

      saveBtn.disabled = true;
      saveBtn.textContent = 'Kaydediliyor…';

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.is_active = form.querySelector('[name="is_active"]').checked;
      payload.has_variant_table = form.querySelector('[name="has_variant_table"]').checked;

      try {
        const res = await fetch('/api/products/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Kaydedilemedi.');
        saveMsg.style.display = 'inline';
        if (!productId) {
          window.location.href = `/products/${data.id}`;
        }
      } catch (err) {
        saveErr.textContent = err.message || 'Kaydedilemedi.';
        saveErr.style.display = 'inline';
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Kaydet';
      }
    });

    document.getElementById('deleteProductBtn')?.addEventListener('click', async () => {
      if (!confirm('Bu ürün ve tüm varyant/teknik verisi silinsin mi? Bu işlem geri alınamaz.')) return;
      const res = await fetch('/api/products/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: productId }),
      });
      if (res.ok) {
        window.location.href = '/products';
      } else {
        alert('Silinemedi, tekrar dene.');
      }
    });

    // Varyant tablosu satır kaydetme/silme
    function readRow(tr) {
      const inputs = tr.querySelectorAll('input');
      let code = '';
      const values = {};
      inputs.forEach((input) => {
        if (input.dataset.field === '__code') code = input.value.trim();
        else values[input.dataset.field] = input.value.trim();
      });
      return { code, values };
    }

    function attachRowHandlers(tr) {
      tr.querySelector('.row-save').addEventListener('click', async () => {
        const btn = tr.querySelector('.row-save');
        const { code, values } = readRow(tr);
        if (!code) {
          alert('Varyant kodu boş olamaz.');
          return;
        }
        btn.disabled = true;
        btn.textContent = '…';
        try {
          const res = await fetch('/api/products/save-variant', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              productId,
              variantId: tr.dataset.variantId || null,
              variantCode: code,
              sortOrder: Array.from(tr.parentNode.children).indexOf(tr),
              values,
            }),
          });
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Kaydedilemedi.');
          tr.dataset.variantId = data.id;
          tr.classList.remove('row-dirty');
          btn.textContent = 'Kaydet';
        } catch (err) {
          alert(err.message || 'Kaydedilemedi.');
          btn.textContent = 'Kaydet';
        } finally {
          btn.disabled = false;
        }
      });

      tr.querySelector('.row-del').addEventListener('click', async () => {
        if (!tr.dataset.variantId) {
          tr.remove();
          return;
        }
        if (!confirm('Bu varyant satırı silinsin mi?')) return;
        const res = await fetch('/api/products/delete-variant', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: tr.dataset.variantId }),
        });
        if (res.ok) {
          tr.remove();
        } else {
          alert('Silinemedi, tekrar dene.');
        }
      });

      tr.querySelectorAll('input').forEach((input) => {
        input.addEventListener('input', () => tr.classList.add('row-dirty'));
      });
    }

    document.querySelectorAll('#vtableBody tr').forEach(attachRowHandlers);

    document.getElementById('addRowBtn')?.addEventListener('click', () => {
      const tbody = document.getElementById('vtableBody');
      const tr = document.createElement('tr');
      tr.classList.add('row-dirty');
      let html = `<td><input type="text" class="code-input" data-field="__code" placeholder="Yeni kod"></td>`;
      fieldKeys.forEach((key) => {
        html += `<td><input type="text" data-field="${key}"></td>`;
      });
      html += `<td class="row-actions"><button type="button" class="row-save">Kaydet</button><button type="button" class="row-del">Sil</button></td>`;
      tr.innerHTML = html;
      tbody.appendChild(tr);
      attachRowHandlers(tr);
      tr.querySelector('.code-input').focus();
    });

    // Künye alanları — her satır kendi kaydet butonuyla
    document.querySelectorAll('.kunye-row').forEach((row) => {
      const attrKey = row.dataset.key;
      row.querySelector('.kunye-save').addEventListener('click', async (e) => {
        const btn = e.target;
        const valueTr = row.querySelector('[data-field="value_tr"]').value;
        const valueEn = row.querySelector('[data-field="value_en"]').value;
        btn.disabled = true;
        btn.textContent = '…';
        try {
          const res = await fetch('/api/products/save-kunye-field', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, attrKey, valueTr, valueEn }),
          });
          if (!res.ok) throw new Error();
          btn.textContent = 'Kaydedildi ✓';
          setTimeout(() => { btn.textContent = 'Kaydet'; }, 1500);
        } catch {
          alert('Kaydedilemedi, tekrar dene.');
          btn.textContent = 'Kaydet';
        } finally {
          btn.disabled = false;
        }
      });
    });

    // Sertifikalar — tek buton, tüm işaretli kutuları gönderir
    document.getElementById('saveCertsBtn')?.addEventListener('click', async () => {
      const btn = document.getElementById('saveCertsBtn');
      const certMsg = document.getElementById('certMsg');
      const tags = Array.from(document.querySelectorAll('#certList input:checked')).map((cb) => cb.value);
      btn.disabled = true;
      btn.textContent = 'Kaydediliyor…';
      try {
        const res = await fetch('/api/products/save-certificates', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, tags }),
        });
        if (!res.ok) throw new Error();
        certMsg.style.display = 'inline';
        setTimeout(() => { certMsg.style.display = 'none'; }, 2000);
      } catch {
        alert('Kaydedilemedi, tekrar dene.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Sertifikaları Kaydet';
      }
    });

    // Uyumlu ürünler — ara, ekle, kaldır
    const compatSearch = document.getElementById('compatSearch');
    const compatResults = document.getElementById('compatResults');
    const compatListEl = document.getElementById('compatList');
    let searchTimer;

    compatSearch?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      const q = compatSearch.value.trim();
      if (q.length < 2) {
        compatResults.style.display = 'none';
        return;
      }
      searchTimer = setTimeout(async () => {
        const res = await fetch(`/api/products/search?q=${encodeURIComponent(q)}&exclude=${productId}`);
        const data = await res.json();
        const existingIds = Array.from(compatListEl.querySelectorAll('.compat-item')).map((el) => el.dataset.id);
        const filtered = (data.results || []).filter((p) => !existingIds.includes(String(p.id)));
        if (filtered.length === 0) {
          compatResults.innerHTML = '<div style="padding:10px 12px;font-size:13px;color:#9ca3af">Sonuç yok</div>';
        } else {
          compatResults.innerHTML = filtered
            .map((p) => `<div class="compat-result" data-id="${p.id}" data-code="${p.prod_code}" data-title="${p.title_tr || p.title_en}" style="padding:9px 12px;font-size:13px;cursor:pointer;border-bottom:1px solid #f1f2f4"><strong>${p.prod_code}</strong> — ${p.title_tr || p.title_en}</div>`)
            .join('');
        }
        compatResults.style.display = 'block';
      }, 250);
    });

    compatResults?.addEventListener('click', async (e) => {
      const item = e.target.closest('.compat-result');
      if (!item) return;
      const compatibleId = item.dataset.id;
      const res = await fetch('/api/products/add-compat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, compatibleId }),
      });
      if (res.ok) {
        const row = document.createElement('div');
        row.className = 'compat-item';
        row.dataset.id = compatibleId;
        row.style = 'display:flex;align-items:center;justify-content:space-between;background:#f4f5f7;padding:8px 12px;border-radius:6px;font-size:13px';
        row.innerHTML = `<span><strong>${item.dataset.code}</strong> — ${item.dataset.title}</span><button type="button" class="compat-remove" style="font-size:11px;color:#b91c1c;background:none;border:none;cursor:pointer">Kaldır</button>`;
        compatListEl.appendChild(row);
        attachCompatRemove(row);
        compatSearch.value = '';
        compatResults.style.display = 'none';
      }
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('#compatSearch') && !e.target.closest('#compatResults')) {
        compatResults.style.display = 'none';
      }
    });

    function attachCompatRemove(row) {
      row.querySelector('.compat-remove').addEventListener('click', async () => {
        const compatibleId = row.dataset.id;
        const res = await fetch('/api/products/remove-compat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, compatibleId }),
        });
        if (res.ok) row.remove();
      });
    }
    document.querySelectorAll('.compat-item').forEach(attachCompatRemove);

    // Excel içe aktarma
    const excelFileInput = document.getElementById('excelFileInput');
    const excelPreview = document.getElementById('excelPreview');
    const excelPreviewSummary = document.getElementById('excelPreviewSummary');
    const excelPreviewError = document.getElementById('excelPreviewError');
    const excelPreviewTable = document.getElementById('excelPreviewTable');
    let pendingRows = null;

    excelFileInput?.addEventListener('change', async () => {
      const file = excelFileInput.files[0];
      if (!file) return;

      excelPreviewError.style.display = 'none';
      const fd = new FormData();
      fd.append('file', file);
      fd.append('productId', productId);

      try {
        const res = await fetch('/api/products/import-excel-preview', { method: 'POST', body: fd });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Dosya okunamadı.');

        pendingRows = data.preview;
        excelPreviewSummary.textContent = `${data.updateCount} satır güncellenecek, ${data.insertCount} satır yeni eklenecek. Kontrol edip onayla.`;

        let html = '<tr><th></th><th>Varyant Kodu</th>' + fieldKeys.map((k) => `<th>${k}</th>`).join('') + '</tr>';
        for (const row of pendingRows) {
          const tag = row.action === 'update' ? '<span class="tag-update">GÜNCELLE</span>' : '<span class="tag-insert">YENİ</span>';
          html += `<tr><td>${tag}</td><td><strong>${row.variantCode}</strong></td>` + fieldKeys.map((k) => `<td>${row.values[k] || ''}</td>`).join('') + '</tr>';
        }
        excelPreviewTable.innerHTML = html;
        excelPreview.style.display = 'block';
        excelPreview.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        excelPreviewError.textContent = err.message || 'Dosya okunamadı.';
        excelPreviewError.style.display = 'block';
        excelPreview.style.display = 'block';
      }
    });

    document.getElementById('excelCancelBtn')?.addEventListener('click', () => {
      excelPreview.style.display = 'none';
      excelFileInput.value = '';
      pendingRows = null;
    });

    document.getElementById('excelApplyBtn')?.addEventListener('click', async () => {
      if (!pendingRows) return;
      const btn = document.getElementById('excelApplyBtn');
      btn.disabled = true;
      btn.textContent = 'Kaydediliyor…';
      try {
        const res = await fetch('/api/products/import-excel-apply', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, rows: pendingRows }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Kaydedilemedi.');
        window.location.reload();
      } catch (err) {
        excelPreviewError.textContent = err.message || 'Kaydedilemedi.';
        excelPreviewError.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Onayla ve Kaydet';
      }
    });

    // Görsel galerisi
    const imageFileInput = document.getElementById('imageFileInput');
    const imageUploadStatus = document.getElementById('imageUploadStatus');

    imageFileInput?.addEventListener('change', async () => {
      const files = Array.from(imageFileInput.files);
      if (files.length === 0) return;
      imageUploadStatus.style.display = 'block';
      for (let i = 0; i < files.length; i++) {
        imageUploadStatus.textContent = `Yükleniyor ${i + 1}/${files.length}…`;
        try {
          const fd = new FormData();
          fd.append('file', files[i]);
          const uploadRes = await fetch('/api/upload', { method: 'POST', body: fd });
          const uploadData = await uploadRes.json();
          if (!uploadRes.ok) throw new Error(uploadData.error);
          await fetch('/api/products/add-image', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId, fileUrl: uploadData.url }),
          });
        } catch (err) {
          alert(`Bir görsel yüklenemedi: ${err.message || 'bilinmeyen hata'}`);
        }
      }
      window.location.reload();
    });

    function currentImageOrder() {
      return Array.from(document.querySelectorAll('.image-card')).map((c) => c.dataset.id);
    }

    document.querySelectorAll('.img-star').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const imageId = btn.closest('.image-card').dataset.id;
        const res = await fetch('/api/products/set-primary-image', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, imageId }),
        });
        if (res.ok) window.location.reload();
      });
    });

    document.querySelectorAll('.img-del').forEach((btn) => {
      btn.addEventListener('click', async () => {
        if (!confirm('Bu görsel silinsin mi?')) return;
        const imageId = btn.closest('.image-card').dataset.id;
        const res = await fetch('/api/products/delete-image', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: imageId }),
        });
        if (res.ok) btn.closest('.image-card').remove();
      });
    });

    document.querySelectorAll('.img-move-up').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('.image-card');
        const prev = card.previousElementSibling;
        if (prev && prev.classList.contains('image-card')) {
          card.parentNode.insertBefore(card, prev);
          await fetch('/api/products/reorder-images', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: currentImageOrder() }),
          });
          window.location.reload();
        }
      });
    });

    document.querySelectorAll('.img-move-down').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const card = btn.closest('.image-card');
        const next = card.nextElementSibling;
        if (next && next.classList.contains('image-card')) {
          card.parentNode.insertBefore(next, card);
          await fetch('/api/products/reorder-images', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: currentImageOrder() }),
          });
          window.location.reload();
        }
      });
    });
  </script>
</AdminLayout>
