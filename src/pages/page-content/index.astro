---
// src/pages/page-content/index.astro
export const prerender = false;

import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAllPageContentAdmin } from '../../lib/queries.js';
import { resolveBrand } from '../../lib/adminUtils.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const brand = resolveBrand(Astro);

const pages = await getAllPageContentAdmin(db, brand);

const PAGE_LABELS = {
  'hakkimizda': 'Hakkımızda',
  'gizlilik-ve-guvenlik': 'Gizlilik ve Güvenlik',
};
const SECTION_LABELS = {
  'ana_metin': 'Ana Metin',
  'kalite_politikasi': 'Kalite Politikamız',
  'gizlilik_metni': 'Tüm Metin',
};
---
<AdminLayout title="Statik Sayfa İçerikleri" activeNav="page-content" showBrandSwitcher brand={brand}>
  <div class="a-page-header">
    <h1 class="a-h1">Statik Sayfa İçerikleri</h1>
  </div>
    <p class="sub">Hakkımızda ve Gizlilik ve Güvenlik sayfalarının metinlerini buradan düzenle.</p>

    {pages.length === 0 && <div class="empty-note">Bu markada henüz içerik yok.</div>}
    {pages.map((p) => (
      <div class="page-block">
        <div class="page-header">{PAGE_LABELS[p.page_key] || p.page_key}</div>
        {p.sections.map((s) => (
          <div class="section-row">
            <div>
              <div class="section-name">{SECTION_LABELS[s.section_key] || s.section_key}</div>
              <div class="section-meta">Son güncelleme: {s.updated_at}</div>
            </div>
            <a class="btn-edit" href={`/page-content/${s.id}`}>Düzenle</a>
          </div>
        ))}
      </div>
    ))}
</AdminLayout>
