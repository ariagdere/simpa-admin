---
// src/pages/fields/index.astro
export const prerender = false;

import { getFieldLabelsGrouped, getDistinctGroups } from '../../lib/queries.js';
import { env } from 'cloudflare:workers';

const db = env.DB;
const groupedFields = await getFieldLabelsGrouped(db);
const distinctGroups = await getDistinctGroups(db);
---
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Teknik Alan Tanımları — Admin Panel</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, 'Segoe UI', Roboto, sans-serif; background: #f4f5f7; color: #1e2535; padding: 32px 24px 60px; }
    .wrap { max-width: 860px; margin: 0 auto; }
    .top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    h1 { font-size: 20px; }
    a.back { font-size: 13px; color: #6b7280; text-decoration: none; }
    .sub { color: #6b7280; font-size: 14px; margin-bottom: 20px; }

    .new-section { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 18px 20px; margin-bottom: 24px; }
    .new-section h2 { font-size: 13px; text-transform: uppercase; letter-spacing: .04em; color: #6b7280; margin-bottom: 12px; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr 90px 1fr; gap: 10px; margin-bottom: 10px; }
    .form-row input, .form-row select { padding: 8px 9px; border: 1px solid #d7d9dd; border-radius: 6px; font-size: 13px; font-family: inherit; }
    .new-group-fields { display: none; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
    .new-group-fields.show { display: grid; }
    .btn-add { background: #1e2535; color: #fff; font-size: 13px; font-weight: 600; padding: 8px 16px; border-radius: 6px; border: none; cursor: pointer; }
    .form-err { font-size: 12.5px; color: #b91c1c; margin-top: 6px; display: none; }

    .group-block { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; margin-bottom: 14px; overflow: hidden; }
    .group-header { background: #f4f5f7; padding: 10px 16px; font-size: 12.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #4a5568; }
    .field-row { display: grid; grid-template-columns: 1fr 1fr 90px 90px; gap: 8px; align-items: center; padding: 8px 16px; border-top: 1px solid #f1f2f4; }
    .field-row input { padding: 6px 8px; border: 1px solid #d7d9dd; border-radius: 5px; font-size: 12.5px; font-family: inherit; }
    .field-key { font-family: ui-monospace, monospace; font-size: 11px; color: #9ca3af; grid-column: 1 / -1; margin-top: -4px; }
    .row-btns { display: flex; gap: 4px; }
    .row-save { font-size: 11px; font-weight: 600; color: #1e5fa8; background: #eff6ff; border: none; border-radius: 4px; padding: 5px 9px; cursor: pointer; }
    .row-del { font-size: 11px; font-weight: 600; color: #b91c1c; background: #fef2f2; border: none; border-radius: 4px; padding: 5px 9px; cursor: pointer; }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <h1>Teknik Alan Tanımları</h1>
      <a class="back" href="/">← Panel</a>
    </div>
    <p class="sub">Ürün varyant tablosundaki sütunları ve gruplarını (Boyutlar, Kilo/Kutu/Ağırlık vb.) buradan yönetirsin. Yeni bir alan eklediğinde, tüm ürünlerin teknik veri tablosunda otomatik yeni sütun olarak belirir.</p>

    <div class="new-section">
      <h2>+ Yeni Alan Tanımla</h2>
      <div class="form-row">
        <input type="text" id="newLabelTr" placeholder="Etiket (TR) *" />
        <input type="text" id="newLabelEn" placeholder="Etiket (EN)" />
        <input type="text" id="newUnit" placeholder="Birim (mm, kg...)" />
        <select id="newGroupSelect">
          <option value="">— Grup yok —</option>
          {distinctGroups.map((g) => <option value={g.group_key}>{g.group_label_tr}</option>)}
          <option value="__new__">+ Yeni grup...</option>
        </select>
      </div>
      <div class="new-group-fields" id="newGroupFields">
        <input type="text" id="newGroupLabelTr" placeholder="Yeni grup adı (TR)" />
        <input type="text" id="newGroupLabelEn" placeholder="Yeni grup adı (EN)" />
      </div>
      <button type="button" class="btn-add" id="addFieldBtn">Ekle</button>
      <div class="form-err" id="addErr"></div>
    </div>

    {groupedFields.map((g) => (
      <div class="group-block">
        <div class="group-header">{g.group_label_tr}</div>
        {g.fields.map((f) => (
          <div class="field-row" data-key={f.attr_key}>
            <input type="text" value={f.label_tr} data-field="label_tr" />
            <input type="text" value={f.label_en || ''} data-field="label_en" placeholder="EN etiket" />
            <input type="text" value={f.unit || ''} data-field="unit" placeholder="birim" />
            <div class="row-btns">
              <button type="button" class="row-save">Kaydet</button>
              <button type="button" class="row-del">Sil</button>
            </div>
            <div class="field-key">{f.attr_key}</div>
          </div>
        ))}
      </div>
    ))}
  </div>

  <script define:vars={{ distinctGroups }}>
    const groupSelect = document.getElementById('newGroupSelect');
    const newGroupFields = document.getElementById('newGroupFields');
    groupSelect.addEventListener('change', () => {
      newGroupFields.classList.toggle('show', groupSelect.value === '__new__');
    });

    document.getElementById('addFieldBtn').addEventListener('click', async () => {
      const errBox = document.getElementById('addErr');
      errBox.style.display = 'none';

      const labelTr = document.getElementById('newLabelTr').value.trim();
      const labelEn = document.getElementById('newLabelEn').value.trim();
      const unit = document.getElementById('newUnit').value.trim();
      let groupKey = groupSelect.value;
      let groupLabelTr = '';
      let groupLabelEn = '';

      if (!labelTr) {
        errBox.textContent = 'Türkçe etiket zorunlu.';
        errBox.style.display = 'block';
        return;
      }

      if (groupKey === '__new__') {
        groupLabelTr = document.getElementById('newGroupLabelTr').value.trim();
        groupLabelEn = document.getElementById('newGroupLabelEn').value.trim();
        if (!groupLabelTr) {
          errBox.textContent = 'Yeni grup adı (TR) zorunlu.';
          errBox.style.display = 'block';
          return;
        }
        groupKey = groupLabelTr.toUpperCase().replace(/[^A-ZÇĞİÖŞÜ0-9]+/g, '_');
      } else {
        const found = distinctGroups.find((g) => g.group_key === groupKey);
        if (found) {
          groupLabelTr = found.group_label_tr;
          groupLabelEn = found.group_label_en;
        }
      }

      try {
        const res = await fetch('/api/fields/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            isNew: true,
            label_tr: labelTr,
            label_en: labelEn,
            unit,
            group_key: groupKey || null,
            group_label_tr: groupLabelTr,
            group_label_en: groupLabelEn,
          }),
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Eklenemedi.');
        window.location.reload();
      } catch (err) {
        errBox.textContent = err.message || 'Eklenemedi.';
        errBox.style.display = 'block';
      }
    });

    document.querySelectorAll('.field-row').forEach((row) => {
      const attrKey = row.dataset.key;
      row.querySelector('.row-save').addEventListener('click', async () => {
        const labelTr = row.querySelector('[data-field="label_tr"]').value.trim();
        const labelEn = row.querySelector('[data-field="label_en"]').value.trim();
        const unit = row.querySelector('[data-field="unit"]').value.trim();
        const res = await fetch('/api/fields/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ isNew: false, attr_key: attrKey, label_tr: labelTr, label_en: labelEn, unit }),
        });
        if (!res.ok) {
          const data = await res.json();
          alert(data.error || 'Kaydedilemedi.');
        }
      });

      row.querySelector('.row-del').addEventListener('click', async () => {
        if (!confirm(`"${attrKey}" alanı silinsin mi?`)) return;
        const res = await fetch('/api/fields/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attr_key: attrKey }),
        });
        const data = await res.json();
        if (res.ok) {
          window.location.reload();
        } else {
          alert(data.error || 'Silinemedi.');
        }
      });
    });
  </script>
</body>
</html>
